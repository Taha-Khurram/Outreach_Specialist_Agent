# Apollo.io
APOLLO_API_KEY=your_apollo_api_key_here

# AI (Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth2 (Gmail, Calendar, Sheets)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/callback
GOOGLE_REFRESH_TOKEN=your_refresh_token_after_setup

# Google Sheets
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Email Settings
SENDER_EMAIL=your_email@gmail.com
SENDER_NAME=Your Name
DAILY_EMAIL_LIMIT=50

# Calendly / Meeting
CALENDLY_LINK=https://calendly.com/your-link/15min
MEETING_DURATION_MINUTES=15

# Agent Settings
PROSPECT_BATCH_SIZE=50
REPLY_CHECK_INTERVAL_MINUTES=5
CONFIDENCE_THRESHOLD=0.8

# Dashboard
MONGODB_URI=mongodb://localhost:27017/client-acquisition
JWT_SECRET=your-super-secret-jwt-key-change-this

# Cron (for external cron services like Vercel Cron, GitHub Actions)
CRON_SECRET=your_cron_secret_here

# Calendly Webhook
CALENDLY_WEBHOOK_SECRET=your_calendly_webhook_signing_key
