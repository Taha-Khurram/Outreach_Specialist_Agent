{
  "apollo": {
    "baseUrl": "https://api.apollo.io/v1",
    "searchQuery": {
      "person_titles": ["CEO", "CTO", "VP Engineering", "Head of Product", "Founder"],
      "organization_num_employees_ranges": ["1,50", "51,200"],
      "person_locations": ["United States"],
      "organization_industry_tag_ids": ["SaaS", "Technology", "E-commerce"],
      "per_page": 50
    },
    "monthlyLimit": 200
  },
  "email": {
    "dailyLimit": 50,
    "trackingHeaders": {
      "X-Task-ID": true,
      "X-Prospect-ID": true
    },
    "unsubscribeText": "\n\n---\nIf you'd rather not hear from us, reply 'unsubscribe' and we'll remove you immediately."
  },
  "ai": {
    "model": "claude-haiku-4-5-20251001",
    "maxTokens": 500,
    "classificationThreshold": 0.8
  },
  "schedule": {
    "discoveryTime": "0 9 * * 1-5",
    "emailSendTime": "0 10 * * 1-5",
    "replyCheckInterval": "*/5 * * * *",
    "reportTime": "0 18 * * 1-5"
  },
  "crm": {
    "statusFlow": ["new", "contacted", "replied", "meeting", "closed", "unsubscribed"],
    "sheetTabs": {
      "prospects": "Prospects",
      "interactions": "Interactions",
      "dashboard": "Dashboard"
    }
  }
}
