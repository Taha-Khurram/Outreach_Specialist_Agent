# Dashboard Environment Variables

# MongoDB (required)
MONGODB_URI=mongodb://localhost:27017/client-acquisition

# JWT Secret - generate a strong random string (required)
JWT_SECRET=your-super-secret-jwt-key-change-this

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Google Gemini AI (for scoring, research, email generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Google OAuth2 (for Gmail send/receive)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# Cron endpoint protection (optional)
CRON_SECRET=your_cron_secret_here

# Calendly webhook verification (optional)
CALENDLY_WEBHOOK_SECRET=your_calendly_webhook_signing_key
